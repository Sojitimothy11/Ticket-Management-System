DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/ticket-management-system"
PORT=3000
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"
SUPPORT_EMAIL_ADDRESS="support@yourdomain.com"
INBOUND_EMAIL_SECRET="generate-with: openssl rand -hex 32"
OPENAI_API_KEY="get from https://platform.openai.com/api-keys"
SENDGRID_API_KEY="get from https://app.sendgrid.com/settings/api_keys"

# In production (single Railway service serving both API and client), BETTER_AUTH_URL
# and FRONTEND_URL must both be set to the app's public URL, e.g. https://your-app.up.railway.app
# The client is built with VITE_API_URL="" in that setup so it calls the API on the same origin.
