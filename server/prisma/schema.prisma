generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets Ticket[] @relation("AssignedTo")
  messages        Message[]
}

model Ticket {
  id           String         @id @default(cuid())
  subject      String
  body         String
  status       TicketStatus   @default(OPEN)
  category     TicketCategory @default(GENERAL_QUESTION)
  customerEmail String
  customerName  String?
  assignedToId  String?
  assignedTo    User?          @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  messages Message[]
}

model Message {
  id         String   @id @default(cuid())
  body       String
  isFromCustomer Boolean @default(false)
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}
